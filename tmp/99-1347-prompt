import { createFileRoute, Link } from "@tanstack/react-router";
import { lazy, type ComponentType } from "react";

const modules = import.meta.glob([
  "../../../components/src/*.tsx",
  "!../../../components/src/*.webflow.tsx",
]) as Record<string, () => Promise<{ default: ComponentType }>>;

const entries = Object.entries(modules);
const componentRegister: Record<string, ComponentType> = {};

for (const [path, loader] of entries) {
  const slug = path.split("/").pop()!.replace(/.tsx$/, "");
  componentRegister[slug] = lazy(loader);
}

export const Route = createFileRoute("/")({
  component: () => {
    return (
      <div className="flex gap-3 p-15">
        {Object.entries(componentRegister).map(([slug, component]) => {
          return (
            <div>
              <Link
                className="hover:bg-gray-400 transition-colors py-2 px-3 rounded-full bg-gray-300"
                to={"/" + slug}
              >
                {slug}
              </Link>
            </div>
          );
        })}
      </div>
    );
  },
});
